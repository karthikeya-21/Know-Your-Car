<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Know Your Car</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-9ndCyUaIbzAi2FUVXJi0CjmCapSmO7SnpJef0486qhLnuZ2cdeRhO02iuK6FUUVM" crossorigin="anonymous">
    <style>
        .form-container {
            width: auto;
            box-shadow: 2px 4px 8px rgba(0, 0, 0, 0.2);
            padding: 30px;
            border-radius: 10px;
        }
        .current-image {
            max-width: 200px;
            max-height: 150px;
            object-fit: contain;
            border-radius: 6px;
            border: 1px solid #dee2e6;
            padding: 6px;
            display: block;
            margin-bottom: 8px;
        }
        #image-preview {
            max-width: 200px;
            max-height: 150px;
            object-fit: contain;
            display: none;
            margin-top: 10px;
            border-radius: 6px;
            border: 1px solid #0d6efd;
            padding: 6px;
        }
    </style>
</head>

<body>
    <% var item = data; %>
    <div class="container mt-4">
        <div class="form-container">
            <h2 class="text-center">Update Car Information</h2>
            <form method="post" action="/update/<%= item.name %>" enctype="multipart/form-data">

                <div class="row mb-3">
                    <label for="name" class="col-md-3 col-form-label">Product Name:</label>
                    <div class="col-md-6">
                        <input type="text" class="form-control" id="name" name="name" value="<%= item.name %>" required>
                    </div>
                </div>

                <div class="row mb-3">
                    <label for="brand" class="col-md-3 col-form-label">Brand:</label>
                    <div class="col-md-6">
                        <input type="text" class="form-control" id="brand" name="brand" value="<%= item.brand %>" required>
                    </div>
                </div>

                <div class="row mb-3">
                    <label for="price" class="col-md-3 col-form-label">Price:</label>
                    <div class="col-md-6">
                        <input type="number" class="form-control" id="price" name="price" step="0.01" value="<%= item.price %>" required>
                    </div>
                </div>

                <div class="row mb-3">
                    <label for="year" class="col-md-3 col-form-label">Year:</label>
                    <div class="col-md-6">
                        <input type="number" class="form-control" id="year" name="year" min="1900" max="2099" value="<%= item.year %>" required>
                    </div>
                </div>

                <div class="row mb-3">
                    <label for="rating" class="col-md-3 col-form-label">Rating:</label>
                    <div class="col-md-6">
                        <input type="number" class="form-control" id="rating" name="rating" min="1" max="5" step="0.1" value="<%= item.rating %>" required>
                    </div>
                </div>

                <h3>Specifications</h3>

                <div class="row mb-3">
                    <label for="fuel" class="col-md-3 col-form-label">Fuel Type:</label>
                    <div class="col-md-6">
                        <input type="text" name="fuel" id="fuel" class="form-control" value="<%= item.specifications.fuel %>" required>
                    </div>
                </div>

                <div class="row mb-3">
                    <label for="engine" class="col-md-3 col-form-label">Engine:</label>
                    <div class="col-md-6">
                        <input type="text" name="engine" id="engine" class="form-control" value="<%= item.specifications.engine %>" required>
                    </div>
                </div>

                <div class="row mb-3">
                    <label for="power" class="col-md-3 col-form-label">Power and Torque:</label>
                    <div class="col-md-6">
                        <input type="text" name="power" id="power" class="form-control" value="<%= item.specifications.power %>" required>
                    </div>
                </div>

                <div class="row mb-3">
                    <label for="drivetrain" class="col-md-3 col-form-label">Drive Train:</label>
                    <div class="col-md-6">
                        <input type="text" name="drivetrain" id="drivetrain" class="form-control" value="<%= item.specifications.drivetrain %>" required>
                    </div>
                </div>

                <div class="row mb-3">
                    <label for="acceleration" class="col-md-3 col-form-label">Acceleration:</label>
                    <div class="col-md-6">
                        <input type="text" name="acceleration" id="acceleration" class="form-control" value="<%= item.specifications.acceleration %>" required>
                    </div>
                </div>

                <div class="row mb-3">
                    <label for="seating" class="col-md-3 col-form-label">Seating Capacity:</label>
                    <div class="col-md-6">
                        <input type="text" name="seating" id="seating" class="form-control" value="<%= item.specifications.seating %>" required>
                    </div>
                </div>

                <div class="row mb-3">
                    <label for="image" class="col-md-3 col-form-label">Car Image:</label>
                    <div class="col-md-6">
                        <% if (item.image) { %>
                            <p class="text-muted mb-1" style="font-size:13px;">Current image:</p>
                            <img src="<%= item.image %>" alt="Current image" class="current-image" />
                        <% } %>
                        <input type="file" class="form-control" id="image" name="image" accept="image/*">
                        <small class="text-muted">Upload a new image to replace the current one. Background will be automatically removed.</small>
                        <img id="image-preview" src="" alt="New image preview" />
                    </div>
                </div>

                <button type="submit" class="btn btn-primary">Update</button>
                <a href="/" class="btn btn-secondary ms-2">Cancel</a>
            </form>
        </div>
    </div>

    <script>
        document.getElementById('image').addEventListener('change', function () {
            const preview = document.getElementById('image-preview');
            const file = this.files[0];
            if (file) {
                preview.src = URL.createObjectURL(file);
                preview.style.display = 'block';
            } else {
                preview.style.display = 'none';
            }
        });
    </script>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>
