<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Know Your Car</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-9ndCyUaIbzAi2FUVXJi0CjmCapSmO7SnpJef0486qhLnuZ2cdeRhO02iuK6FUUVM" crossorigin="anonymous">
    <style>
        .form-container {
            width: auto;
            box-shadow: 2px 4px 8px rgba(0, 0, 0, 0.2);
            padding: 30px;
            border-radius: 10px;
        }
        #logo-preview {
            max-width: 120px;
            max-height: 120px;
            object-fit: contain;
            display: none;
            margin-top: 10px;
            border-radius: 6px;
            border: 1px solid #dee2e6;
            padding: 6px;
        }
    </style>
</head>

<body>
    <div class="container mt-4">
        <div class="form-container">
            <h2 class="text-center">Add Brand</h2>
            <form method="post" action="/insertbrand" enctype="multipart/form-data">
                <div class="row mb-3">
                    <label for="brand" class="col-md-3 col-form-label">Brand Name:</label>
                    <div class="col-md-6">
                        <input type="text" class="form-control" id="brand" name="brand" required>
                    </div>
                </div>

                <div class="row mb-3">
                    <label for="logo" class="col-md-3 col-form-label">Brand Logo:</label>
                    <div class="col-md-6">
                        <input type="file" class="form-control" id="logo" name="logo" accept="image/*" required>
                        <small class="text-muted">Background will be automatically removed before saving.</small>
                        <img id="logo-preview" src="" alt="Preview" />
                    </div>
                </div>

                <button type="submit" class="btn btn-primary">Submit</button>
            </form>
        </div>
    </div>

    <script>
        document.getElementById('logo').addEventListener('change', function () {
            const preview = document.getElementById('logo-preview');
            const file = this.files[0];
            if (file) {
                preview.src = URL.createObjectURL(file);
                preview.style.display = 'block';
            } else {
                preview.style.display = 'none';
            }
        });
    </script>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>
